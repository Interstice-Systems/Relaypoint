{
  "name": "relaypoint",
  "version": "1.0.0",
  "description": "Deterministic evidence infrastructure for AI-assisted software engineering.",
  "type": "module",
  "bin": {
    "relaypoint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "V1_RELEASE_CRITERIA.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "relaypoint": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "software-engineering",
    "qa",
    "handoff",
    "evidence",
    "code-review",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Interstice-Systems/Relaypoint.git"
  },
  "homepage": "https://github.com/Interstice-Systems/Relaypoint",
  "bugs": {
    "url": "https://github.com/Interstice-Systems/Relaypoint/issues"
  },
  "author": "Interstice Systems",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
